{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebFetch(domain:*)",
      "WebSearch",
      "Bash(rg *)",
      "Bash(bat *)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(pwd)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr comment *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(git fetch *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(parted *)",
      "Bash(chown -R *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(poweroff *)",
      "Bash(init 0 *)",
      "Bash(init 6 *)",
      "Bash(kill -9 -1 *)",
      "Bash(mv /* *)",
      "Bash(mv ~ *)",
      "Bash(format *)",
      "Bash(> /dev/sd *)",
      "Bash(diskutil eraseDisk *)",
      "Bash(diskutil eraseVolume *)",
      "Bash(diskutil partitionDisk *)",
      "Bash(diskutil secureErase *)",
      "Bash(tmutil delete *)",
      "Bash(tmutil disable *)",
      "Bash(tmutil deletelocalsnapshots *)",
      "Bash(nvram *)",
      "Bash(csrutil *)",
      "Bash(spctl *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/config)",
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(//**/.envrc)",
      "Read(//**/*.pem)",
      "Read(//**/*.key)",
      "Read(//**/id_rsa)",
      "Read(//**/id_ed25519)",
      "Read(//**/credentials.json)",
      "Read(//**/service-account*.json)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Write(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Edit(~/.config/gh/hosts.yml)",
      "Write(~/.config/gh/hosts.yml)",
      "Edit(~/.netrc)",
      "Write(~/.netrc)",
      "Edit(~/.npmrc)",
      "Write(~/.npmrc)",
      "Edit(~/.pypirc)",
      "Write(~/.pypirc)",
      "Edit(~/.docker/config.json)",
      "Write(~/.docker/config.json)",
      "Edit(~/.kube/config)",
      "Write(~/.kube/config)",
      "Edit(//**/*.pem)",
      "Write(//**/*.pem)",
      "Edit(//**/*.key)",
      "Write(//**/*.key)",
      "Edit(//**/id_rsa)",
      "Write(//**/id_rsa)",
      "Edit(//**/id_ed25519)",
      "Write(//**/id_ed25519)",
      "Edit(//**/credentials.json)",
      "Write(//**/credentials.json)",
      "Edit(//**/service-account*.json)",
      "Write(//**/service-account*.json)",
      "Edit(~/.zshrc)",
      "Write(~/.zshrc)",
      "Edit(~/.zshenv)",
      "Write(~/.zshenv)",
      "Edit(~/.zprofile)",
      "Write(~/.zprofile)",
      "Edit(~/.zlogin)",
      "Write(~/.zlogin)",
      "Edit(~/.bashrc)",
      "Write(~/.bashrc)",
      "Edit(~/.bash_profile)",
      "Write(~/.bash_profile)",
      "Edit(~/.profile)",
      "Write(~/.profile)",
      "Edit(~/.config/fish/config.fish)",
      "Write(~/.config/fish/config.fish)",
      "Edit(~/.config/fish/conf.d/**)",
      "Write(~/.config/fish/conf.d/**)",
      "Edit(~/.gitconfig)",
      "Write(~/.gitconfig)",
      "Edit(~/.config/git/config)",
      "Write(~/.config/git/config)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/bash-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/play-notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/play-notification.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/tpane_first_prompt.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "skipAutoPermissionPrompt": true
}
