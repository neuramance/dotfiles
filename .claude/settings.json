{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebFetch(domain:*)",
      "WebSearch",
      "Bash(rg *)",
      "Bash(bat *)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(pwd)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr comment *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(git fetch *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(parted *)",
      "Bash(chown -R *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(poweroff *)",
      "Bash(init 0 *)",
      "Bash(init 6 *)",
      "Bash(kill -9 -1 *)",
      "Bash(mv /* *)",
      "Bash(mv ~ *)",
      "Bash(format *)",
      "Bash(> /dev/sd *)",
      "Bash(diskutil eraseDisk *)",
      "Bash(diskutil eraseVolume *)",
      "Bash(diskutil partitionDisk *)",
      "Bash(diskutil secureErase *)",
      "Bash(tmutil delete *)",
      "Bash(tmutil disable *)",
      "Bash(tmutil deletelocalsnapshots *)",
      "Bash(nvram *)",
      "Bash(csrutil *)",
      "Bash(spctl *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/play-notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/play-notification.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/tpane_first_prompt.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
