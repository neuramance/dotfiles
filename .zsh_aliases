# sudo wrapper: use sudo if available, otherwise run directly
_sudo() { if command -v sudo &>/dev/null; then sudo "$@"; else "$@"; fi }

# shell
alias c="clear"
alias cd..="cd .."
alias zconf="code ~/.zshrc"
alias ls="eza -bhlF --no-user --no-permissions --no-time --group-directories-first"
alias sl="eza -bhlF --no-user --no-permissions --no-time --group-directories-first"
alias lsa="eza -abhlF --no-user --no-permissions --no-time --group-directories-first"
if command -v batcat &>/dev/null; then
  alias bat="batcat"
elif command -v bat &>/dev/null; then
  : # bat is already bat
fi
alias atop="_sudo asitop --color 7"

# git
alias gits="git status"
alias gita="git add ."
alias gitd="git diff"
alias gitc="git commit"
alias gitp="git push"
alias gitpu="git pull"
alias glg="git log --graph --pretty=format:'%C(blue)%h %C(black)%ad%C(magenta)%d %C(brightblack)%s' --abbrev=4 --all --date=format:'%y-%m-%d %H:%M'"
# Identity-switching helpers (gitpersonal, gitgauntlet, etc.) live in
# ~/.zsh_aliases.local — kept out of this public repo so emails/names are
# not pushed. Sourced at the bottom of this file if present.

# python
alias py="python3"
alias python="python3"
alias pip="pip3"
alias deac="deactivate"

# homebrew
alias brewbundle="brew bundle -f dump"
alias brewup="brew update && brew upgrade"

# apt
alias aptup="_sudo apt update && _sudo apt upgrade"
alias aptsetup="bash ~/.config/scripts/apt-setup.sh"

# mac
alias macsetup="bash ~/.config/scripts/mac-setup.sh"

# npm
alias nrd="npm run dev"

# bun
alias brd="bun run dev"
alias brdo="bun run dev -- --open"
alias brb="bun run build"

# tmux
alias tmls="tmux list-sessions"
alias tmdev="script -c tmux /dev/null"
alias tma="tmux attach"
alias tmka="tmux kill-server"

# echo PATH formatted (must be sourced after PATH is fully set)
alias echopath="echo '$PATH' | tr ':' '\n'"

# Claude Code
alias ccd="claude --dangerously-skip-permissions"
alias cdw="claude --dangerously-skip-permissions -w"

alias senv="source .venv/bin/activate"

# meridian dev servers
alias nrdd="npm run dev:demo"
alias nrt="npm run dev:testnet"

# Local-only overrides (identity helpers, machine-specific aliases, etc.)
[ -f "$HOME/.zsh_aliases.local" ] && source "$HOME/.zsh_aliases.local"
